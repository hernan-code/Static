/*
precios de articulos
*/

SELECT
	p2.DESCRIPCION AS PLANVENTA,
	CASE WHEN A.COMBO = 0 THEN 'FULL PRICE' ELSE 'PROMO' END AS ETIQUETA_DE_PRECIO,
	p.IDARTICULO,
	a.DESCRIPCION AS ARTICULO,
	M.DESCRIPCION AS MARCA,
	F.DESCRIPCION AS FAMILIA,
	L.DESCRIPCION AS LINEA,
	p.PRECIO
FROM 
    PRECIO p
INNER JOIN PLANVENTA p2
	ON p2.IDPLANVENTA = p.IDPLANVENTA
INNER JOIN ARTICULO a
	ON p.IDARTICULO = a.IDARTICULO
INNER JOIN FAMILIAARTICULO f 
	ON F.IDFAMILIA = A.IDFAMILIA 
INNER JOIN LINEA l 
	ON L.IDLINEA = A.IDLINEA 
INNER JOIN MARCA m 
	ON M.IDMARCA = A.IDMARCA 
WHERE
    p.precio <> 0
    AND p2.estado = 'A'
    AND P2.IDPLANVENTA LIKE :IDPLANVENTA
GROUP BY
	p.IDARTICULO,
	a.DESCRIPCION,
	p.PRECIO,
	p2.DESCRIPCION,
	F.DESCRIPCION,
	L.DESCRIPCION,
	M.DESCRIPCION,
	A.COMBO 
ORDER BY M.DESCRIPCION ASC, F.DESCRIPCION ASC
