precios de articulos - pivot por plan de venta (canal)
*/
SELECT
    p.IDARTICULO,
    a.DESCRIPCION AS ARTICULO,
    F.DESCRIPCION AS FAMILIA,
    L.DESCRIPCION AS LINEA,
    MAX(CASE WHEN p2.DESCRIPCION = 'SALON' 				THEN p.PRECIO END) AS SALON,
    MAX(CASE WHEN p2.DESCRIPCION = 'DELIVERY' 			THEN p.PRECIO END) AS DELIVERY,
    MAX(CASE WHEN p2.DESCRIPCION = 'CARRY OUT' 			THEN p.PRECIO END) AS CARRY_OUT,
    MAX(CASE WHEN p2.DESCRIPCION = 'EXPRESS' 			THEN p.PRECIO END) AS EXPRESS,
    MAX(CASE WHEN p2.DESCRIPCION = 'MONCHIS'  			THEN p.PRECIO END) AS MONCHIS,
    MAX(CASE WHEN p2.DESCRIPCION = 'PEDIDOSYA'  		THEN p.PRECIO END) AS PEDIDOS_YA,
    MAX(CASE WHEN p2.DESCRIPCION = 'EVENTOS' 			THEN p.PRECIO END) AS EVENTOS,
    MAX(CASE WHEN p2.DESCRIPCION = 'MAYORISTA' 			THEN p.PRECIO END) AS MAYORISTA,
    MAX(CASE WHEN p2.DESCRIPCION = 'PEDIDOSYA_PICK_UP'	THEN p.PRECIO END) AS PEDIDOSYA_PICK_UP,
    MAX(CASE WHEN p2.DESCRIPCION = 'ENEX'    			THEN p.PRECIO END) AS ENEX,
    MAX(CASE WHEN p2.DESCRIPCION = 'COSTO'  			THEN p.PRECIO END) AS COSTO,
    MAX(CASE WHEN p2.DESCRIPCION = 'COSTOUSD'           THEN p.PRECIO END) AS COSTOUSD
    --SUM(p.PRECIO) AS TOTAL_RESULTADO
FROM
    PRECIO p
INNER JOIN PLANVENTA p2
    ON p2.IDPLANVENTA = p.IDPLANVENTA
INNER JOIN ARTICULO a
    ON p.IDARTICULO = a.IDARTICULO
INNER JOIN FAMILIAARTICULO f
    ON F.IDFAMILIA = A.IDFAMILIA
INNER JOIN LINEA l
    ON L.IDLINEA = A.IDLINEA
WHERE
    p.PRECIO <> 0
    AND p2.ESTADO = 'A'
    AND p2.DESCRIPCION <> '(Desconocido)'
    AND p2.IDPLANVENTA LIKE :IDPLANVENTA
    AND CAST(p.IDARTICULO AS VARCHAR(20)) LIKE :IDARTICULO
GROUP BY
    p.IDARTICULO,
    a.DESCRIPCION,
    F.DESCRIPCION,
    L.DESCRIPCION
ORDER BY
    F.DESCRIPCION ASC, a.DESCRIPCION ASC
