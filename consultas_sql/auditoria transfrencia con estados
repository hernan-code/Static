SELECT
      M.IDMOVIMIENTO,
      M.FECHA_CARGA,
      CASE EXTRACT(WEEKDAY FROM M.FECHA_CARGA)
          WHEN 0 THEN 'Domingo'
          WHEN 1 THEN 'Lunes'
          WHEN 2 THEN 'Martes'
          WHEN 3 THEN 'Miércoles'
          WHEN 4 THEN 'Jueves'
          WHEN 5 THEN 'Viernes'
          WHEN 6 THEN 'Sábado'
      END AS DIA_SEMANA_CARGA,
      M.FECHA,
      CASE EXTRACT(WEEKDAY FROM M.FECHA)
          WHEN 0 THEN 'Domingo'
          WHEN 1 THEN 'Lunes'
          WHEN 2 THEN 'Martes'
          WHEN 3 THEN 'Miércoles'
          WHEN 4 THEN 'Jueves'
          WHEN 5 THEN 'Viernes'
          WHEN 6 THEN 'Sábado'
      END AS DIA_SEMANA,
      
      M.IDTIPOMOVIMIENTO,
      T."DESCRIPCION",
      D.IDARTICULO,
      A."DESCRIPCION" AS ARTICULO,
      D.IDDEPOSITO,
      DE."DESCRIPCION" AS DEPOSITO_ORIGEN,
      D.IDDEPOSITO1,
      DE1."DESCRIPCION" AS DEPOSITO_DESTINO,
      D.CANTIDAD,
      M.IDTALONARIO,
      M.IDPERSONA,
      M.VENCIMIENTO,
      M.NROMOVIMIENTO,
      M.NROPEDIDO,
      M.NROREMISION,
      M.ESTADO,
      CASE M.ESTADO
          WHEN 'A' THEN 'Anulado'
          WHEN 'B' THEN 'Bloqueado'
          WHEN 'F' THEN 'Impreso'
          WHEN 'I' THEN 'Interno'
          WHEN 'P' THEN 'Pendiente'
      END AS ESTADO_DESC,
      M.IDMONEDA,
      M.IDPEDIDO,
      M.IDUSER,
      M.IDCONTROLCAJA,
      M.PSPT_REF,
      M.PSPT_ENTREGA,
      M.FECHA_STOCK
  FROM MOVIMIENTOS M
  JOIN TIPOMOVIMIENTO T ON T.IDTIPOMOVIMIENTO = M.IDTIPOMOVIMIENTO
  JOIN DETALLEMOVIMIENTO D ON D.IDMOVIMIENTO = M.IDMOVIMIENTO
  JOIN ARTICULO A ON A.IDARTICULO = D.IDARTICULO
  LEFT JOIN DEPOSITO DE  ON DE.IDDEPOSITO  = D.IDDEPOSITO
  LEFT JOIN DEPOSITO DE1 ON DE1.IDDEPOSITO = D.IDDEPOSITO1
  WHERE M.IDTIPOMOVIMIENTO IN (14, 42, 74)
    AND M.FECHA >= '2026-03-01'
    AND M.FECHA <= '2026-06-02'
    AND NOT (
          EXTRACT(YEAR  FROM M.FECHA) = EXTRACT(YEAR  FROM M.FECHA_CARGA)
      AND EXTRACT(MONTH FROM M.FECHA) = EXTRACT(MONTH FROM M.FECHA_CARGA)
      AND EXTRACT(DAY   FROM M.FECHA) = EXTRACT(DAY   FROM M.FECHA_CARGA)
    )
  ORDER BY M.FECHA, M.IDMOVIMIENTO, D.ORDEN;
