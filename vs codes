def revisar(service, vistas):
    conn = conectar_db()
    cur = conn.cursor()

    cursos = service.courses().list(courseStates=["ACTIVE"]).execute().get("courses", [])
    for curso in cursos:
        if not any(m.lower() in curso["name"].lower() for m in MIS_MATERIAS):
            continue

        # Guardar curso en la base de datos
        cur.execute("""
            INSERT INTO cursos (id, nombre)
            VALUES (%s, %s)
            ON CONFLICT (id) DO NOTHING
        """, (curso["id"], curso["name"]))

        tareas = service.courses().courseWork().list(
            courseId=curso["id"]
        ).execute().get("courseWork", [])

        for tarea in tareas:
            if tarea["id"] not in vistas:
                print(f" Nueva tarea: {tarea.get('title')} en {curso['name']}")

                # Fecha límite
                fecha = None
                if "dueDate" in tarea:
                    d = tarea["dueDate"]
                    fecha = f"{d.get('year')}-{d.get('month')}-{d.get('day')}"

                # Guardar tarea en la base de datos
                cur.execute("""
                    INSERT INTO tareas (id, curso_id, titulo, descripcion, fecha_limite, puntos, enlace)
                    VALUES (%s, %s, %s, %s, %s, %s, %s)
                    ON CONFLICT (id) DO NOTHING
                """, (
                    tarea["id"],
                    curso["id"],
                    tarea.get("title", ""),
                    tarea.get("description", ""),
                    fecha,
                    tarea.get("maxPoints"),
                    tarea.get("alternateLink", "")
                ))

                # Guardar notificación
                cur.execute("""
                    INSERT INTO notificaciones (tarea_id, email_enviado)
                    VALUES (%s, %s)
                """, (tarea["id"], False))

                ayuda = pedir_ayuda_claude(tarea.get("title", ""), tarea.get("description", ""))
                enviar_email(tarea, curso["name"], ayuda)  

                # Actualizar notificación como enviada
                cur.execute("""
                    UPDATE notificaciones SET email_enviado = TRUE
                    WHERE tarea_id = %s
                """, (tarea["id"],))

                vistas[tarea["id"]] = True

    conn.commit()
    cur.close()
    conn.close()
    return vistas

